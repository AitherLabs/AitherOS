# AitherOS Frontend — copy to .env.local and fill in your values

# NextAuth — must match your deployment URL
NEXTAUTH_URL=https://your-domain.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_generate_with_openssl_rand_base64_32

# Backend API public URL (served to browser — must be reachable from the user's browser)
NEXT_PUBLIC_API_URL=https://your-backend-domain.com

# Backend API internal URL (used by Next.js server-side — can be a local address)
# Leave as-is for same-host installs
BACKEND_URL=http://127.0.0.1:8080

# JWT secret — must match the backend JWT_SECRET
NEXTAUTH_JWT_SECRET=change_me_same_as_backend_JWT_SECRET
