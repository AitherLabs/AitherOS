# AitherOS Environment Configuration — copy to .env and fill in your values

# ─── Installation ─────────────────────────────────────
# Root directory of the AitherOS installation.
# Change this if you cloned to a different path (e.g. /home/user/AitherOS).
INSTALL_ROOT=/opt/AitherOS

# ─── Server ───────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
ENVIRONMENT=production

# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=aitheros
POSTGRES_PASSWORD=change_me
POSTGRES_DB=aitheros
DATABASE_URL=postgres://aitheros:change_me@127.0.0.1:5432/aitheros?sslmode=disable

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://127.0.0.1:6379/0

# ─── JWT / Auth ───────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
JWT_EXPIRY=24h

# ─── PicoClaw Agent Engine ────────────────────────────
PICOCLAW_URL=http://127.0.0.1:55000
PICOCLAW_TIMEOUT=120s

# ─── LLM Proxy (LiteLLM) ─────────────────────────────
LLM_API_BASE=http://127.0.0.1:4000/v1
LLM_API_KEY=your_litellm_or_openai_key
LLM_MODEL=gpt-4o-mini

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ─── Encryption Key (for sensitive agent configs) ─────
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change_me_generate_with_openssl_rand_base64_32

# ─── Auth tokens ──────────────────────────────────────
# One-time token required to register the first admin user.
# Remove or leave empty to disable open registration.
REGISTRATION_TOKEN=change_me_or_remove_to_disable_registration

# Internal service-to-service token (used by Aither-Tools MCP to call back
# into the AitherOS API). Generate with: openssl rand -hex 32
SERVICE_TOKEN=change_me_generate_with_openssl_rand_hex_32

# Internal API URL used by MCP servers to call back into the backend.
# Leave as-is for same-host installs; change only if backend is on a different host.
AITHER_API_URL=http://127.0.0.1:8080
